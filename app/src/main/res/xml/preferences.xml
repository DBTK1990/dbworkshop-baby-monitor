<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        android:title="Authentication">
        <EditTextPreference
            android:key="username"
            android:title="Username"
            android:defaultValue=""
            android:singleLine="true" />
        <EditTextPreference
            android:key="password"
            android:title="Password"
            android:defaultValue=""
            android:inputType="textPassword"
            android:singleLine="true" />
        <EditTextPreference
            android:key="endpoint_rate_limit_per_minute"
            android:title="Endpoint Rate Limit (requests/min)"
            android:summary="Maximum requests per IP per endpoint each minute"
            android:defaultValue="120"
            android:inputType="number"
            android:singleLine="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Camera Registration">
        <EditTextPreference
            android:key="registration_url"
            android:title="Registration URL"
            android:summary="Cluster webhook URL for dynamic IP update"
            android:defaultValue="https://camera-reg.dbworkshop.org/register-camera"
            android:singleLine="true" />
        <EditTextPreference
            android:key="registration_token"
            android:title="Registration API Token"
            android:summary="Bearer token sent to the registration endpoint"
            android:inputType="textPassword"
            android:singleLine="true" />
        <SwitchPreference
            android:key="registration_bypass_ssl"
            android:title="Bypass SSL Verification"
            android:summary="Accept self-signed or internal CA certificates for the registration endpoint. Enable only when your server uses a private certificate."
            android:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Certificate Settings">
        <Preference
            android:key="certificate_path"
            android:title="Custom TLS Certificate" android:summary="Select your own certificate" android:persistent="true" />
        <EditTextPreference
            android:key="certificate_password"
            android:title="Certificate Password"
            android:summary="Optional password for the TLS certificate"
            android:persistent="true"
            android:inputType="textPassword" />
        <Preference
            android:key="test_certificate"
            android:title="Test Certificate Setup"
            android:summary="Validate your certificate configuration"
            android:persistent="false" />
    </PreferenceCategory>
</PreferenceScreen>
