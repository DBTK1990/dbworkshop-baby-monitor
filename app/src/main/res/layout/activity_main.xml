<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Tab bar -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabIndicatorColor="#4CAF50"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <!-- Page content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ─── Camera tab ─── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cameraPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/noClientMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="24dp"
                android:gravity="center"
                android:padding="16dp"
                android:text="No users are connected, visit the URL below to start the camera"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="#80000000"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/topRightButtonBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="16dp"
                android:gravity="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_preferences"
                    android:contentDescription="Settings" />
                <ImageButton
                    android:id="@+id/hidePreviewButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_view"
                    android:contentDescription="Toggle Preview" />
                <ImageButton
                    android:id="@+id/exitButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="Exit App" />
            </LinearLayout>

            <TextView
                android:id="@+id/ipAddressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="16dp"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="#80000000"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ─── Logs tab ─── -->
        <LinearLayout
            android:id="@+id/logPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#0A0A0A">

            <EditText
                android:id="@+id/logSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Filter logs (regex)…"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:background="#1A1A1A"
                android:padding="12dp"
                android:singleLine="true"
                android:inputType="text"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/logRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scrollbars="vertical"
                android:padding="4dp"
                android:clipToPadding="false" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>

